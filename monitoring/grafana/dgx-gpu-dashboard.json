{
  "__comment": "monitoring/grafana/dgx-gpu-dashboard.json — Import via Grafana UI: Dashboards → Import → Upload JSON",
  "title": "NVIDIA DGX Cluster — GPU Health",
  "uid": "dgx-gpu-health-v1",
  "tags": ["nvidia", "dgx", "gpu", "dcgm"],
  "timezone": "browser",
  "schemaVersion": 38,
  "refresh": "30s",
  "time": { "from": "now-1h", "to": "now" },

  "templating": {
    "list": [
      {
        "name": "node",
        "type": "query",
        "datasource": "Prometheus",
        "query": "label_values(DCGM_FI_DEV_GPU_UTIL, instance)",
        "label": "DGX Node",
        "multi": true,
        "includeAll": true
      },
      {
        "name": "gpu",
        "type": "query",
        "datasource": "Prometheus",
        "query": "label_values(DCGM_FI_DEV_GPU_UTIL{instance=~\"$node\"}, gpu)",
        "label": "GPU Index",
        "multi": true,
        "includeAll": true
      }
    ]
  },

  "panels": [
    {
      "id": 1,
      "title": "GPU Utilization (%)",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 0, "w": 12, "h": 8 },
      "targets": [
        {
          "expr": "DCGM_FI_DEV_GPU_UTIL{instance=~\"$node\", gpu=~\"$gpu\"}",
          "legendFormat": "{{instance}} GPU{{gpu}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "min": 0, "max": 100,
          "thresholds": {
            "steps": [
              { "value": 0, "color": "red" },
              { "value": 15, "color": "yellow" },
              { "value": 70, "color": "green" }
            ]
          }
        }
      }
    },
    {
      "id": 2,
      "title": "GPU Temperature (°C)",
      "type": "timeseries",
      "gridPos": { "x": 12, "y": 0, "w": 12, "h": 8 },
      "targets": [
        {
          "expr": "DCGM_FI_DEV_GPU_TEMP{instance=~\"$node\", gpu=~\"$gpu\"}",
          "legendFormat": "{{instance}} GPU{{gpu}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "celsius",
          "thresholds": {
            "steps": [
              { "value": 0, "color": "green" },
              { "value": 75, "color": "yellow" },
              { "value": 85, "color": "red" }
            ]
          }
        }
      }
    },
    {
      "id": 3,
      "title": "GPU Power Draw (W)",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 8, "w": 12, "h": 8 },
      "targets": [
        {
          "expr": "DCGM_FI_DEV_POWER_USAGE{instance=~\"$node\", gpu=~\"$gpu\"}",
          "legendFormat": "{{instance}} GPU{{gpu}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "watt",
          "thresholds": {
            "steps": [
              { "value": 0, "color": "green" },
              { "value": 650, "color": "yellow" },
              { "value": 750, "color": "red" }
            ]
          }
        }
      }
    },
    {
      "id": 4,
      "title": "HBM Memory Used (GB)",
      "type": "timeseries",
      "gridPos": { "x": 12, "y": 8, "w": 12, "h": 8 },
      "targets": [
        {
          "expr": "DCGM_FI_DEV_FB_USED{instance=~\"$node\", gpu=~\"$gpu\"} / 1024",
          "legendFormat": "{{instance}} GPU{{gpu}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "decgbytes",
          "thresholds": {
            "steps": [
              { "value": 0, "color": "green" },
              { "value": 60, "color": "yellow" },
              { "value": 76, "color": "red" }
            ]
          }
        }
      }
    },
    {
      "id": 5,
      "title": "XID Errors (rate 5m)",
      "type": "stat",
      "gridPos": { "x": 0, "y": 16, "w": 8, "h": 4 },
      "targets": [
        {
          "expr": "sum(increase(DCGM_FI_DEV_XID_ERRORS{instance=~\"$node\"}[5m]))",
          "legendFormat": "XID Errors"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "steps": [
              { "value": 0, "color": "green" },
              { "value": 1, "color": "red" }
            ]
          }
        }
      }
    },
    {
      "id": 6,
      "title": "NVLink Bandwidth (GB/s)",
      "type": "timeseries",
      "gridPos": { "x": 8, "y": 16, "w": 16, "h": 4 },
      "targets": [
        {
          "expr": "DCGM_FI_DEV_NVLINK_BANDWIDTH_TOTAL{instance=~\"$node\"}",
          "legendFormat": "{{instance}} NVLink"
        }
      ]
    }
  ]
}
